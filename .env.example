# Google Calendar
# 1) Habilitar Google Calendar API en el proyecto de Google Cloud
# 2) Crear una Service Account y descargar la key JSON
# 3) Copiar desde el JSON: client_email -> GOOGLE_CALENDAR_CLIENT_EMAIL
# 4) Copiar desde el JSON: private_key -> GOOGLE_CALENDAR_PRIVATE_KEY
# 5) En Google Calendar, compartir el calendario con el client_email de la Service Account
# 6) Dar permiso "Hacer cambios en eventos"
# 7) Copiar el "Calendar ID" desde Google Calendar -> Integrate calendar
GOOGLE_CALENDAR_CLIENT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREEMPLAZAR_POR_TU_PRIVATE_KEY\n-----END PRIVATE KEY-----\n
GOOGLE_CALENDAR_ID=tu_calendar_id@group.calendar.google.com
GOOGLE_CALENDAR_TIMEZONE=America/Argentina/Buenos_Aires
GOOGLE_CALENDAR_WORK_START=16:00
GOOGLE_CALENDAR_WORK_END=19:00
GOOGLE_CALENDAR_SLOT_MINUTES=30
GOOGLE_CALENDAR_DAYS_AHEAD=7
